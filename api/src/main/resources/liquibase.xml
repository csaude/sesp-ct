    <!-- Create main Pedido table -->
    <changeSet id="sespct-1.0.0-1" author="sespct">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="sespct_pedido"/>
            </not>
        </preConditions>
        <comment>Create sespct_pedido table</comment>

        <createTable tableName="sespct_pedido">
            <column name="pedido_id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <!-- Standard OpenMRS audit fields -->
            <column name="uuid" type="char(38)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="creator" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="date_created" type="datetime">
                <constraints nullable="false"/>
            </column>
            <column name="changed_by" type="int"/>
            <column name="date_changed" type="datetime"/>
            <column name="voided" type="tinyint" defaultValue="0">
                <constraints nullable="false"/>
            </column>
            <column name="voided_by" type="int"/>
            <column name="date_voided" type="datetime"/>
            <column name="void_reason" type="varchar(255)"/>

            <!-- Core metadata fields -->
            <column name="pedidoId" type="varchar(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="data_submissao" type="datetime"/>
            <column name="versao" type="varchar(10)"/>
            <column name="origem" type="varchar(50)"/>
            <column name="tipo_formulario" type="varchar(20)"/>
            <column name="solicitado_por" type="varchar(100)"/>
            <column name="estado" type="varchar(50)"/>
            <column name="causa" type="varchar(50)"/>
        </createTable>

        <!-- Foreign key constraints to users -->
        <addForeignKeyConstraint
                baseTableName="sespct_pedido"
                baseColumnNames="creator"
                referencedTableName="users"
                referencedColumnNames="user_id"
                constraintName="fk_pedido_creator"/>

        <addForeignKeyConstraint
                baseTableName="sespct_pedido"
                baseColumnNames="changed_by"
                referencedTableName="users"
                referencedColumnNames="user_id"
                constraintName="fk_pedido_changed_by"/>

        <addForeignKeyConstraint
                baseTableName="sespct_pedido"
                baseColumnNames="voided_by"
                referencedTableName="users"
                referencedColumnNames="user_id"
                constraintName="fk_pedido_voided_by"/>

        <!-- Indexes -->
        <createIndex tableName="sespct_pedido" indexName="idx_pedido_pedidoId">
            <column name="pedidoId"/>
        </createIndex>

        <createIndex tableName="sespct_pedido" indexName="idx_pedido_estado">
            <column name="estado"/>
        </createIndex>
    </changeSet>


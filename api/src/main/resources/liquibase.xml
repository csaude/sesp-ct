            <!-- Standard OpenMRS audit fields -->
            <column name="uuid" type="char(38)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="creator" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="date_created" type="datetime">
                <constraints nullable="false"/>
            </column>
            <column name="changed_by" type="int"/>
            <column name="date_changed" type="datetime"/>
            <column name="voided" type="tinyint" defaultValue="0">
                <constraints nullable="false"/>
            </column>
            <column name="voided_by" type="int"/>
            <column name="date_voided" type="datetime"/>
            <column name="void_reason" type="varchar(255)"/>
            
            <!-- Foreign key to main request -->
            <column name="request_id" type="int">
                <constraints nullable="false"/>
            </column>
            
            <!-- CD4 specific fields -->
            <column name="data_exame" type="date"/>
            <column name="cd4_value" type="int"/>
            <column name="cd4_percentagem" type="double"/>
        </createTable>
        
        <!-- Add foreign key constraint -->
        <addForeignKeyConstraint 
            constraintName="sespct_cd4_data_request_fk"
            baseTableName="sespct_cd4_data" baseColumnNames="request_id"
            referencedTableName="sespct_request" referencedColumnNames="request_id"/>
            
        <addForeignKeyConstraint 
            constraintName="sespct_cd4_data_creator_fk"
            baseTableName="sespct_cd4_data" baseColumnNames="creator"
            referencedTableName="users" referencedColumnNames="user_id"/>
    </changeSet>

    <!-- Create Viral Load Data table -->
    <changeSet id="sespct-1.0.0-4" author="sespct">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="sespct_viral_load_data"/>
            </not>
        </preConditions>
        <comment>Create sespct_viral_load_data table</comment>
        
        <createTable tableName="sespct_viral_load_data">
            <column name="viral_load_data_id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            
            <!-- Standard OpenMRS audit fields -->
            <column name="uuid" type="char(38)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="creator" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="date_created" type="datetime">
                <constraints nullable="false"/>
            </column>
            <column name="changed_by" type="int"/>
            <column name="date_changed" type="datetime"/>
            <column name="voided" type="tinyint" defaultValue="0">
                <constraints nullable="false"/>
            </column>
            <column name="voided_by" type="int"/>
            <column name="date_voided" type="datetime"/>
            <column name="void_reason" type="varchar(255)"/>
            
            <!-- Foreign key to main request -->
            <column name="request_id" type="int">
                <constraints nullable="false"/>
            </column>
            
            <!-- Viral Load specific fields -->
            <column name="data_exame" type="date"/>
            <column name="carga_viral" type="int"/>
        </createTable>
        
        <!-- Add foreign key constraint -->
        <addForeignKeyConstraint 
            constraintName="sespct_viral_load_data_request_fk"

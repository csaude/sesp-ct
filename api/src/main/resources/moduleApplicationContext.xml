<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
                           http://www.springframework.org/schema/beans/spring-beans-3.0.xsd
                           http://www.springframework.org/schema/context
                           http://www.springframework.org/schema/context/spring-context-3.0.xsd">

    <!-- Enable annotation-based configuration -->
    <context:component-scan base-package="org.openmrs.module.sespct" />

    <!-- Define the DAO bean with sessionFactory injection -->
    <bean id="pedidoDao" class="org.openmrs.module.sespct.api.dao.impl.PedidoDaoImpl">
        <property name="dbSessionFactory" ref="dbSessionFactory" />
    </bean>
    
    <bean id="sespct.RespostaDao" class="org.openmrs.module.sespct.api.dao.impl.RespostaDaoImpl">
    	<property name="sessionFactory" ref="sessionFactory"/>
	</bean>

    <!-- Define the service implementation -->
    <bean id="pedidoServiceImpl"
          class="org.openmrs.module.sespct.api.impl.PedidoServiceImpl">
        <property name="pedidoDao" ref="pedidoDao" />
    </bean>
    
    <bean id="sespct.RespostaService" class="org.openmrs.module.sespct.api.impl.RespostaServiceImpl">
    	<property name="respostaDao" ref="sespct.RespostaDao"/>
	</bean>

    <!-- Register the service with OpenMRS Context -->
    <bean parent="serviceContext">
        <property name="moduleService">
            <list>
                <value>org.openmrs.module.sespct.api.PedidoService</value>
                <ref bean="pedidoServiceImpl" />
            </list>
        </property>
    </bean>
</beans>
	<!-- Extensions -->
	<extension>
		<id>sespct.header.navigation</id>
		<point>org.openmrs.gutter.tools</point>
		<class>org.openmrs.module.sespct.extension.html.GutterListExt</class>
	</extension>

	<aware_of_modules>
		<aware_of_module>org.openmrs.module.legacyui</aware_of_module>
	</aware_of_modules>

